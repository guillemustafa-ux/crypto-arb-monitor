# ─────────────────────────────────────────────────────────────────────────────
# Monitor de Arbitraje Cambiario Argentino — configuración
# Copiá este archivo a `.env` y completá los valores.
# Datos provistos por la API pública de CriptoYa (criptoya.com/api).
# ─────────────────────────────────────────────────────────────────────────────

# ── Par a monitorear ─────────────────────────────────────────────────────────
COIN=usdt
FIAT=ars
# Volumen (en unidades de COIN) para pedir cotizaciones a CriptoYa.
VOLUME=1

# ── Frente A: dólar tradicional vs cripto ────────────────────────────────────
# Tipos de dólar a comparar (oficial, blue, mep, ccl).
DOLLAR_TYPES=oficial,blue,mep,ccl
# Bono y término usados para resolver MEP/CCL (CriptoYa los anida por bono).
MEP_BOND=al30
CCL_BOND=al30
BOND_TERM=24hs
# Ganancia neta mínima (%) para alertar una oportunidad del Frente A.
MIN_NET_PCT_A=1.0

# ── Frente B: solo cripto (USDT/ARS) ─────────────────────────────────────────
# Modalidades activas: spot_spot, p2p_p2p, spot_p2p, same_brand
B_MODES=spot_spot,p2p_p2p,spot_p2p,same_brand
# Ganancia neta mínima (%) para alertar una oportunidad del Frente B.
MIN_NET_PCT_B=0.5
# Whitelist de plataformas (ids de CriptoYa, separados por coma).
# Vacío = se monitorean TODAS las que devuelva la API.
# Ej: binance,binancep2p,buenbit,ripio,lemoncash,belo,fiwind,letsbit,satoshitango
PLATFORMS=

# ── Monitoreo ────────────────────────────────────────────────────────────────
# Cada cuántos segundos se consulta CriptoYa.
POLL_INTERVAL=60
# Minutos de espera entre alertas de la MISMA ruta (anti-spam).
ALERT_COOLDOWN_MIN=15

# ── Telegram ─────────────────────────────────────────────────────────────────
# Crear bot con @BotFather → token. chat_id: enviar un mensaje al bot y consultar
# https://api.telegram.org/bot<token>/getUpdates  → result[].message.chat.id
# Si dejás estos vacíos, el monitor corre igual pero no envía alertas.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Persistencia ─────────────────────────────────────────────────────────────
# Local: ./arb.db  |  Railway con volumen montado en /data: /data/arb.db
DB_PATH=./arb.db

# Puerto del dashboard. Railway inyecta PORT automáticamente.
PORT=8000

# ── Comisiones extra opcionales (en %, NO incluidas en el total de CriptoYa) ──
# CriptoYa ya devuelve totalAsk/totalBid netos de la comisión de cada plataforma.
# Usá esto solo para sumar costos que la API no contempla (ej. transferencia
# bancaria/CBU al operar contra el dólar tradicional). Formato: EXTRA_FEE_<ID>.
# EXTRA_FEE_BINANCE=0.1
# EXTRA_FEE_LEMONCASH=0.0
